<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_main">

    <!-- Orbs -->
    <View android:layout_width="260dp" android:layout_height="260dp"
        android:background="@drawable/bg_orb_blue"
        android:translationX="80dp" android:translationY="-60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View android:layout_width="200dp" android:layout_height="200dp"
        android:background="@drawable/bg_orb_teal"
        android:translationX="-50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Header text block -->
    <TextView android:id="@+id/tvGoalTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:text="Choose Your Target"
        android:textSize="28sp" android:textStyle="bold"
        android:textColor="#F8FAFC" android:textAlignment="center"
        android:layout_marginBottom="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View android:id="@+id/goalAccentBar"
        android:layout_width="40dp" android:layout_height="3dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_accent_bar"
        app:layout_constraintTop_toBottomOf="@id/tvGoalTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView android:id="@+id/tvGoalSubtitle"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="40dp" android:layout_marginEnd="40dp"
        android:text="Select the academic context you are preparing for. The system will adapt the blueprint quotas accordingly."
        android:textSize="14sp" android:textColor="#64748B"
        android:textAlignment="center" android:lineSpacingExtra="3dp"
        app:layout_constraintTop_toBottomOf="@id/goalAccentBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Goal card -->
    <LinearLayout android:id="@+id/btnDostSei"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_goal_card"
        android:paddingTop="28dp" android:paddingBottom="28dp"
        android:paddingStart="24dp" android:paddingEnd="24dp"
        android:layout_marginStart="28dp" android:layout_marginEnd="28dp"
        android:layout_marginTop="48dp"
        android:clickable="true" android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/tvGoalSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🎓" android:textSize="36sp"
            android:layout_marginBottom="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DOST-SEI" android:textSize="20sp" android:textStyle="bold"
            android:textColor="#60A5FA" android:textAlignment="center"
            android:layout_marginBottom="4dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Undergraduate Scholarship"
            android:textSize="13sp" android:textColor="#94A3B8"
            android:textAlignment="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>