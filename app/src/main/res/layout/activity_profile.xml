<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_main">

    <!-- Glowing Orbs matching dashboard and results -->
    <View android:layout_width="300dp" android:layout_height="300dp"
        android:background="@drawable/bg_orb_blue"
        android:translationX="80dp" android:translationY="-60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View android:layout_width="240dp" android:layout_height="240dp"
        android:background="@drawable/bg_orb_teal"
        android:translationX="-50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Top header bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Back"
            app:tint="#F8FAFC"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textColor="#F8FAFC"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            android:layout_marginStart="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Profile Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Profile Avatar Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileHeader"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="50dp"
                app:cardBackgroundColor="#1E293B"
                app:strokeWidth="2.5dp"
                app:strokeColor="#2563EB"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="👤"
                    android:textSize="48sp"
                    android:gravity="center" />

            </com.google.android.material.card.MaterialCardView>

            <!-- User Name -->
            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#F8FAFC"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/cardProfileHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="Algian Aquillo" />

            <!-- User Email -->
            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/tvProfileName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="algian@example.com" />

            <!-- User Rank Badge -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#2563EB20"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2563EB50"
                app:layout_constraintTop_toBottomOf="@id/tvProfileEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tvProfileRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:textColor="#60A5FA"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    tools:text="SCHOLAR" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Stats section -->
            <TextView
                android:id="@+id/tvStatsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="PERFORMANCE STATISTICS"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:layout_constraintTop_toBottomOf="@id/cardRank"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Core metrics cards (Grid structure via nested constraints) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#0D1B3E"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FFFFFF10"
                app:layout_constraintTop_toBottomOf="@id/tvStatsTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cardStreak"
                android:layout_marginEnd="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Total SP"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvProfileSp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#F59E0B"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="450" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStreak"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D1B3E"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FFFFFF10"
                app:layout_constraintTop_toTopOf="@id/cardSp"
                app:layout_constraintStart_toEndOf="@id/cardSp"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯 Active Streak"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvProfileStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#EF4444"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="5 Days" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardExams"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#0D1B3E"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FFFFFF10"
                app:layout_constraintTop_toBottomOf="@id/cardSp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cardAccuracy"
                android:layout_marginEnd="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Exams Taken"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvProfileExams"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#10B981"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="12" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAccuracy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#0D1B3E"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FFFFFF10"
                app:layout_constraintTop_toTopOf="@id/cardExams"
                app:layout_constraintStart_toEndOf="@id/cardExams"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 Avg Accuracy"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvProfileAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#60A5FA"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="85%" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Logout button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="40dp"
                android:text="Logout from Account"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.04"
                app:backgroundTint="#EF4444"
                app:cornerRadius="14dp"
                app:elevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/cardExams"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1B3E"
        app:itemIconTint="#2563EB"
        app:itemTextColor="#94A3B8"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
