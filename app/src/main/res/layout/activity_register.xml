<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cognita_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <!-- ── Back Button ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/bg_btn_icon"
                android:src="@drawable/ic_arrow_left"
                android:contentDescription="Go back"
                android:padding="8dp" />

        </FrameLayout>

        <!-- ── Brand Block ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Process in motion."
                android:textSize="12sp"
                android:textColor="@color/cognita_text_secondary"
                android:textAlignment="center"
                android:letterSpacing="0.04"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join Cognita"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/cognita_text_primary"
                android:textAlignment="center"
                android:layout_marginBottom="8dp" />

            <View
                android:layout_width="36dp"
                android:layout_height="3dp"
                android:background="@drawable/bg_accent_bar" />

        </LinearLayout>

        <!-- ── Form Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/cognita_surface"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="14dp">

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full name"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/cognita_text_primary"
                android:letterSpacing="0.05"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etRegFullName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Alex Santos"
                android:inputType="textPersonName"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="14sp"
                android:textColor="@color/cognita_text_primary"
                android:textColorHint="@color/cognita_text_secondary"
                android:layout_marginBottom="12dp" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email address"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/cognita_text_primary"
                android:letterSpacing="0.05"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etRegEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="14sp"
                android:textColor="@color/cognita_text_primary"
                android:textColorHint="@color/cognita_text_secondary"
                android:layout_marginBottom="12dp" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/cognita_text_primary"
                android:letterSpacing="0.05"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etRegPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="14sp"
                android:textColor="@color/cognita_text_primary"
                android:textColorHint="@color/cognita_text_secondary"
                android:layout_marginBottom="12dp" />

            <!-- Confirm Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm password"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/cognita_text_primary"
                android:letterSpacing="0.05"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etRegConfirm"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:background="@drawable/bg_input_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="14sp"
                android:textColor="@color/cognita_text_primary"
                android:textColorHint="@color/cognita_text_secondary"
                android:layout_marginBottom="20dp" />

            <!-- Primary button: explicit backgroundTint overrides theme -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Create Account"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:letterSpacing="0.05"
                app:backgroundTint="@color/cognita_primary"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

        </LinearLayout>

        <!-- ── Divider ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Already have an account?  "
                android:textSize="11sp"
                android:textColor="@color/cognita_text_secondary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_divider" />

        </LinearLayout>

        <!-- Outlined secondary button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Sign In"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/cognita_primary"
            android:letterSpacing="0.05"
            app:backgroundTint="@color/cognita_surface"
            app:strokeColor="@color/cognita_primary"
            app:strokeWidth="2dp"
            app:cornerRadius="14dp"
            app:elevation="0dp" />

    </LinearLayout>
</ScrollView>