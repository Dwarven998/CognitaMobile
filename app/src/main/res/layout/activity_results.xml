<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_main">

    <!-- Orb top-right -->
    <View android:layout_width="300dp" android:layout_height="300dp"
        android:background="@drawable/bg_orb_blue"
        android:translationX="80dp" android:translationY="-60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Orb bottom-left -->
    <View android:layout_width="240dp" android:layout_height="240dp"
        android:background="@drawable/bg_orb_teal"
        android:translationX="-50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Session complete label -->
    <TextView android:id="@+id/tvSessionLabel"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="SESSION COMPLETE"
        android:textSize="12sp" android:textStyle="bold"
        android:textColor="#60A5FA" android:letterSpacing="0.12"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Score ring -->
    <FrameLayout android:id="@+id/scoreRing"
        android:layout_width="160dp" android:layout_height="160dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_score_ring"
        app:layout_constraintTop_toBottomOf="@id/tvSessionLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Glow behind score -->
        <View android:layout_width="120dp" android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_logo_glow" />

        <TextView android:id="@+id/tvFinalScore"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:text="18 / 20"
            android:textSize="28sp" android:textStyle="bold"
            android:textColor="#F8FAFC" android:gravity="center" />

    </FrameLayout>

    <!-- Accent bar -->
    <View android:id="@+id/resultsAccent"
        android:layout_width="40dp" android:layout_height="3dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_accent_bar"
        app:layout_constraintTop_toBottomOf="@id/scoreRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Stats row -->
    <LinearLayout android:id="@+id/statsRow"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginStart="28dp" android:layout_marginEnd="28dp"
        app:layout_constraintTop_toBottomOf="@id/resultsAccent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- SP Earned -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_dark_card"
            android:paddingTop="20dp" android:paddingBottom="20dp"
            android:layout_marginEnd="8dp">

            <TextView android:id="@+id/tvSpGained"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="+180 SP"
                android:textStyle="bold" android:textColor="#60A5FA"
                android:textSize="22sp" android:layout_marginBottom="4dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Earned" android:textSize="12sp" android:textColor="#64748B" />

        </LinearLayout>

        <!-- Accuracy -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_dark_card"
            android:paddingTop="20dp" android:paddingBottom="20dp"
            android:layout_marginStart="8dp">

            <TextView android:id="@+id/tvAccuracy"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="90%"
                android:textStyle="bold" android:textColor="#10B981"
                android:textSize="22sp" android:layout_marginBottom="4dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Accuracy" android:textSize="12sp" android:textColor="#64748B" />

        </LinearLayout>

    </LinearLayout>

    <!-- Return button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReturnHome"
        android:layout_width="0dp" android:layout_height="54dp"
        android:layout_marginStart="28dp" android:layout_marginEnd="28dp"
        android:layout_marginBottom="48dp"
        android:text="Return to Dashboard"
        android:textSize="15sp" android:textStyle="bold"
        android:textColor="#FFFFFF" android:letterSpacing="0.04"
        app:backgroundTint="@color/cognita_primary"
        app:cornerRadius="14dp" app:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>