<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="24dp">

    <ProgressBar
        android:id="@+id/pbExamProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:progressDrawable="@drawable/bg_button_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvTimer"
        android:layout_marginEnd="16dp"
        tools:progress="40" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="51dp"
        android:layout_height="20dp"
        android:textColor="@color/colorSecondary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/pbExamProgress"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="14:59" />

    <TextView
        android:id="@+id/tvQuestionProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Question 4 of 10"
        android:textColor="@color/colorTextSecondary"
        android:textSize="14sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/pbExamProgress"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageButton
        android:id="@+id/btnFlagQuestion"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_flag"
        android:contentDescription="Flag Question"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvQuestionProgress"
        app:layout_constraintBottom_toBottomOf="@id/tvQuestionProgress" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="16dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/colorSurfaceVariant"
        app:layout_constraintTop_toBottomOf="@id/tvQuestionProgress">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivOblationLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:alpha="0.05"
                android:src="@drawable/up_oblation"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="What is the time complexity of a binary search algorithm?"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/cardQuestion"
        app:layout_constraintBottom_toTopOf="@id/btnNext">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioGroup
                android:id="@+id/rgOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rbOptionA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:background="@drawable/bg_rounded_card"
                    android:buttonTint="@color/colorPrimary"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/colorTextPrimary"
                    tools:text="O(n)" />

                <RadioButton
                    android:id="@+id/rbOptionB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:background="@drawable/bg_rounded_card"
                    android:buttonTint="@color/colorPrimary"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/colorTextPrimary"
                    tools:text="O(log n)" />

                <RadioButton
                    android:id="@+id/rbOptionC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:background="@drawable/bg_rounded_card"
                    android:buttonTint="@color/colorPrimary"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/colorTextPrimary"
                    tools:text="O(n^2)" />

                <RadioButton
                    android:id="@+id/rbOptionD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:background="@drawable/bg_rounded_card"
                    android:buttonTint="@color/colorPrimary"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/colorTextPrimary"
                    tools:text="O(1)" />
            </RadioGroup>

            <TextView
                android:id="@+id/tvTriviaEntry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_rounded_card"
                android:padding="16dp"
                android:textColor="@color/colorTextSecondary"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:visibility="gone"
                tools:text="Trivia entry: Binary search repeatedly divides the search interval in half."
                tools:visibility="visible" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Next Question"
        android:textColor="@color/colorOnPrimary"
        android:background="@drawable/bg_button_primary"
        app:backgroundTint="@null"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>