<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cognita_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp">

        <!-- ── Brand Block ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="40dp">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_btn_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="C"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COGNITA"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/cognita_text_primary"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@drawable/bg_accent_bar"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back. Sign in to continue."
                android:textSize="14sp"
                android:textColor="@color/cognita_text_secondary"
                android:textAlignment="center" />

        </LinearLayout>

        <!-- ── Login Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/cognita_surface"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email address"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/cognita_text_primary"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"
                android:textColor="@color/cognita_text_primary"
                android:textColorHint="@color/cognita_text_secondary"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Password"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/cognita_text_primary"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot password?"
                    android:textSize="12sp"
                    android:textColor="@color/cognita_primary"
                    android:textStyle="bold" />

            </LinearLayout>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"
                android:textColor="@color/cognita_text_primary"
                android:textColorHint="@color/cognita_text_secondary"
                android:layout_marginBottom="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Sign In"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:letterSpacing="0.05"
                app:backgroundTint="@color/cognita_primary"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

        </LinearLayout>

        <!-- ── Divider ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  New here?  "
                android:textSize="12sp"
                android:textColor="@color/cognita_text_secondary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_divider" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create an Account"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/cognita_primary"
            android:letterSpacing="0.05"
            app:backgroundTint="@color/cognita_surface"
            app:strokeColor="@color/cognita_primary"
            app:strokeWidth="2dp"
            app:cornerRadius="14dp"
            app:elevation="0dp" />

    </LinearLayout>
</ScrollView>