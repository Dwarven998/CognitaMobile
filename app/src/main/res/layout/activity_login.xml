<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Orb top-right -->
            <View
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:background="@drawable/bg_orb_blue"
                android:translationX="80dp"
                android:translationY="-60dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Orb bottom-left -->
            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/bg_orb_teal"
                android:translationX="-50dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="72dp"
                android:paddingBottom="40dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Brand Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="36dp">

                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginBottom="20dp">

                        <View android:layout_width="100dp" android:layout_height="100dp"
                            android:background="@drawable/bg_ring_outer" />

                        <View android:layout_width="76dp" android:layout_height="76dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_logo_glow" />

                        <FrameLayout android:layout_width="58dp" android:layout_height="58dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_logo_circle">
                            <TextView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="C" android:textSize="26sp"
                                android:textStyle="bold" android:textColor="#FFFFFF"
                                android:gravity="center" />
                        </FrameLayout>

                    </FrameLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="COGNITA" android:textSize="30sp" android:textStyle="bold"
                        android:textColor="#F8FAFC" android:letterSpacing="0.15"
                        android:layout_marginBottom="8dp" />

                    <View android:layout_width="40dp" android:layout_height="3dp"
                        android:background="@drawable/bg_accent_bar"
                        android:layout_marginBottom="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Welcome back. Sign in to continue."
                        android:textSize="14sp" android:textColor="#94A3B8"
                        android:textAlignment="center" />

                </LinearLayout>

                <!-- Login Card -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_dark_card"
                    android:paddingStart="24dp" android:paddingEnd="24dp"
                    android:paddingTop="28dp" android:paddingBottom="28dp"
                    android:layout_marginBottom="20dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Email address" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#94A3B8" android:letterSpacing="0.06"
                        android:layout_marginBottom="6dp" />

                    <EditText android:id="@+id/etEmail" android:layout_width="match_parent"
                        android:layout_height="52dp" android:hint="you@example.com"
                        android:inputType="textEmailAddress" android:background="@drawable/bg_dark_input"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="14sp" android:textColor="#F8FAFC"
                        android:textColorHint="#475569" android:layout_marginBottom="18dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Password"
                            android:textSize="11sp" android:textStyle="bold"
                            android:textColor="#94A3B8" android:letterSpacing="0.06" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Forgot password?" android:textSize="11sp"
                            android:textColor="#60A5FA" android:textStyle="bold" />

                    </LinearLayout>

                    <EditText android:id="@+id/etPassword" android:layout_width="match_parent"
                        android:layout_height="52dp" android:hint="••••••••"
                        android:inputType="textPassword" android:background="@drawable/bg_dark_input"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:textSize="14sp" android:textColor="#F8FAFC"
                        android:textColorHint="#475569" android:layout_marginBottom="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="Sign In" android:textSize="15sp" android:textStyle="bold"
                        android:textColor="#FFFFFF" android:letterSpacing="0.05"
                        app:backgroundTint="@color/cognita_primary"
                        app:cornerRadius="14dp" app:elevation="0dp" />

                </LinearLayout>

                <!-- Divider -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="#FFFFFF18" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  New here?  " android:textSize="12sp" android:textColor="#475569" />

                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="#FFFFFF18" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToRegister"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="Create an Account" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/cognita_primary"
                    android:letterSpacing="0.05"
                    app:backgroundTint="#FFFFFF0D"
                    app:strokeColor="@color/cognita_primary" app:strokeWidth="1dp"
                    app:cornerRadius="14dp" app:elevation="0dp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</ScrollView>